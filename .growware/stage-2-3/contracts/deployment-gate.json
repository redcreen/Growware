{
  "schema": "growware.stage23.contract.v1",
  "id": "growware.stage23.deployment-gate.v1",
  "title": "Deployment Gate Contract",
  "kind": "stage-contract",
  "status": "active-draft",
  "contract_type": "deployment-gate",
  "owners": [
    "growware"
  ],
  "depends_on": [
    "docs/reference/growware/pilot-loop-v1.md",
    "docs/reference/growware/stage-2-3-baseline.md"
  ],
  "required_sections": [
    "purpose",
    "action_classes",
    "gate_decisions",
    "required_approval_payload",
    "rollback_rules",
    "emergency_constraints",
    "machine_notes"
  ],
  "sections": {
    "purpose": {
      "title": "Purpose",
      "items": [],
      "text": "This contract defines what Stage 2 actions may continue automatically, which ones must stop for approval, and how rollback remains constrained."
    },
    "action_classes": {
      "title": "Action Classes",
      "items": [
        "read-only-status",
        "verification-only",
        "user-visible-change",
        "deploy",
        "rollback",
        "policy-or-contract-change"
      ],
      "text": ""
    },
    "gate_decisions": {
      "title": "Gate Decisions",
      "items": [
        "`read-only-status`: continue without deploy approval",
        "`verification-only`: continue when project policy allows the declared checks",
        "`user-visible-change`: stop for approval",
        "`deploy`: stop for approval",
        "`rollback`: stop for approval unless a later emergency contract explicitly narrows the exception",
        "`policy-or-contract-change`: stop for approval"
      ],
      "text": ""
    },
    "required_approval_payload": {
      "title": "Required Approval Payload",
      "items": [
        "project_id",
        "incident_id",
        "action_class",
        "requested_effect",
        "verification_ref",
        "risk_summary",
        "requested_at"
      ],
      "text": ""
    },
    "rollback_rules": {
      "title": "Rollback Rules",
      "items": [
        "rollback still requires explicit scope, evidence, and target environment",
        "rollback does not erase the need for close-out provenance",
        "rollback-triggering incidents must still preserve the original deploy context"
      ],
      "text": ""
    },
    "emergency_constraints": {
      "title": "Emergency Constraints",
      "items": [
        "no emergency exception exists by default in this repo",
        "future emergency rules must be defined explicitly rather than inferred from urgency alone"
      ],
      "text": ""
    },
    "machine_notes": {
      "title": "Machine Notes",
      "items": [
        "compile `action_classes`, `gate_decisions`, `required_approval_payload`, `rollback_rules`, and `emergency_constraints` as separate arrays"
      ],
      "text": ""
    }
  },
  "source_docs": [
    "docs/reference/growware/stage-2-3-contracts/deployment-gate.md",
    "docs/reference/growware/stage-2-3-contracts/deployment-gate.zh-CN.md"
  ]
}
